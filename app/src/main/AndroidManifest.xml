<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 短信读取权限 - 用于自动识别收支 -->
    <uses-permission android:name="android.permission.READ_SMS" />
    
    <!-- 接收短信权限 -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    
    <!-- 网络权限 - 用于可能的数据同步 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 通知监听服务使用权（需要用户在系统设置中手动授权） -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- 震动权限 - 自动记账提示 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- 发送通知权限 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 全屏意图权限 - 锁屏时显示通知 -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- 安装APK权限 - 应用内更新 -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- 开机自启动权限 - 重启后重绑通知监听服务 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 悬浮窗权限 - 后台弹出界面 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 相机和相册权限 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:name=".TinyLedgerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TinyLedger">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TinyLedger">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- 深色模式设置页面 -->
        <activity
            android:name=".ui.screens.settings.DarkModeSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.TinyLedger" />
        
        <!-- SMS接收器 - 用于实时监听新短信 -->
        <receiver 
            android:name=".data.sms.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- 通知监听服务 - 实时监听微信/支付宝收支通知 -->
        <service
            android:name=".data.notification.TransactionNotificationService"
            android:exported="true"
            android:label="小小记账本通知监听"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:stopWithTask="false"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- 交易确认通知操作接收器 -->
        <receiver
            android:name=".data.notification.TransactionActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.tinyledger.app.ACTION_CONFIRM_TRANSACTION" />
                <action android:name="com.tinyledger.app.ACTION_DELETE_TRANSACTION" />
                <action android:name="com.tinyledger.app.ACTION_EDIT_TRANSACTION" />
            </intent-filter>
        </receiver>

        <!-- 开机自启动接收器 - 重启后重绑通知监听服务 -->
        <receiver
            android:name=".data.notification.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.miui.home.action.LAUNCH" />
            </intent-filter>
        </receiver>

        <!-- FileProvider - 用于安装下载的APK -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
